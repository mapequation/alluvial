{
  "name": "alluvial-monorepo",
  "version": "1.14.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build:lib": "npm run build -w @mapequation/alluvial-diagram",
    "build:app": "npm run build -w apps/web",
    "build": "npm run build:lib && npm run build:app",
    "preview": "npm run preview -w apps/web",
    "test": "npm run test -w @mapequation/alluvial-diagram && npm run test -w apps/web",
    "test:watch": "npm run test:watch -w apps/web"
  },
  "devDependencies": {
    "prettier": "^2.4.1",
    "typescript": "^6.0.3"
  }
}
